<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/app_background"
    android:paddingTop="38dp">

    <!-- Твоя красивая плашка из Home -->
    <LinearLayout
        android:id="@+id/search_bar_active"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/search_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="@color/accent_green" />

        <EditText
            android:id="@+id/search_input"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:hint="Искать в Spring"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch" />
    </LinearLayout>

    <!-- 1. СПИСОК ПОДХОДЯЩИХ КАТЕГОРИЙ (Живой поиск по категориям) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/suggestions_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/search_bar_active"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:elevation="5dp" />

    <!-- 2. РЕЗУЛЬТАТЫ ТОВАРОВ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_results_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_bar_active"
        android:layout_marginTop="12dp"
        android:padding="2dp"
        android:visibility="visible" />

</RelativeLayout>