<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/main_sapphire"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/cart_product_image"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/placeholder_gray"
            android:scaleType="centerCrop"
            android:clipToOutline="true"/>

        <!-- Цена на уровне верхней части картинки, название под ней, расположены очень близко и правее картинки -->
        <TextView
            android:id="@+id/cart_product_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cart_product_image"
            android:layout_alignTop="@id/cart_product_image"
            android:layout_marginStart="12dp"
            android:text="100 ₽"
            android:textColor="@color/price_antique"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cart_product_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cart_product_image"
            android:layout_below="@id/cart_product_price"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Product Title"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:ellipsize="end"
            android:maxLines="2" />

        <TextView
            android:id="@+id/cart_product_unit_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cart_product_image"
            android:layout_below="@id/cart_product_title"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_gray_light"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="100 ₽ / шт." />

        <!-- Controls under the image -->
        <LinearLayout
            android:id="@+id/controls_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/cart_product_image"
            android:layout_alignParentStart="true"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_remove"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_trash"
                android:background="@drawable/rounded_cart_controls_bg"
                android:padding="6dp"
                android:scaleType="fitCenter"
                app:tint="@color/text_gray_light" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_cart_controls_bg"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_decrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_minus"
                    android:background="@android:color/transparent"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_gray_light" />

                <TextView
                    android:id="@+id/tv_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="1"
                    android:textColor="@color/text_gray_light"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_increase"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_plus"
                    android:background="@android:color/transparent"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_gray_light" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/checkbox_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/controls_layout"
            android:layout_alignBottom="@id/controls_layout"
            app:buttonTint="@color/checkbox_tint" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>
