<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_sapphire"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarCheckout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/main_sapphire"
            app:titleTextColor="@color/text_white" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Товары к оформлению"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_white" 
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewCheckoutProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Тип оплаты"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radioOnline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Онлайн"
                    android:textColor="@color/text_white"
                    android:buttonTint="@color/accent_green"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/radioUponReceipt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="При получении"
                    android:buttonTint="@color/accent_green"
                    android:textColor="@color/text_white"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пункт выдачи"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/accent_green" app:boxBackgroundColor="@color/white"
                android:layout_marginBottom="16dp"
                android:textColorHint="#757575"
                app:hintTextColor="@color/accent_green">

                <AutoCompleteTextView
                    android:id="@+id/spinnerPickupPoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/black"
                    android:popupBackground="@color/white"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#1A1A1A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvCheckoutTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Итого: 0.00 $"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green" 
                android:layout_gravity="center_vertical"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Оформить заказ"
                app:backgroundTint="@color/accent_green"
                android:textColor="@color/black"
                app:cornerRadius="15dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
